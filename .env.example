# Copy to .env (gitignored) and fill in. The Python tools source this via
# `set -a; source .env; set +a` (the Makefile does it for you).

# The station profile — the directory holding THIS instance's identity and content
# (place, prompts, curated lore, sources, language). Absolute path. Unset = the shipped
# reference profile at stations/example (a nameless, English-only station). Make your own
# with `make new-station NAME=yourplace`, then point this at stations/yourplace.
#   STATION_PROFILE=/absolute/path/to/your/station/profile

# Gemini image generation — only needed to (re)generate illustrations.
# Paid model; the key's Google Cloud project must have billing enabled.
GEMINI_API_KEY=

# BirdNET listener — location weighting + which microphone to use.
# REQUIRED. BirdNET weights species by location, so a borrowed or wrong location
# yields confidently wrong birds. No default ships — set your station's coordinates.
BIRD_LAT=
BIRD_LON=
# The station's place — the instance's identity, shown in the footer/title/panels
# and given to the summary model. Config wins; otherwise it's resolved from the
# almanac's reverse-geocode (never hard-coded in the app). BIRD_PLACE_GA is the
# optional Irish rendering (falls back to BIRD_PLACE). Open-Meteo needs no API key.
#   BIRD_PLACE=Yourplace
#   BIRD_PLACE_GA=
BIRD_MIN_CONF=0.5
# Mic name substring; list devices with:
#   uv run python -c "import sounddevice; print(sounddevice.query_devices())"
BIRD_MIC=USBMIC1

# Google sign-in (OAuth). Create an OAuth 2.0 Client (type: Web application) in
# the Google Cloud console, add the callback URL as an Authorized redirect URI
# (e.g. http://localhost:4030/auth/google_oauth2/callback for dev, and the
# device/cloud URL for real), then paste the credentials here.
#   GOOGLE_CLIENT_ID=
#   GOOGLE_CLIENT_SECRET=
# Comma-separated admin emails (station settings etc.); unset = nobody is admin.
#   ADMIN_EMAILS=you@example.com

# --- Pi / production only (leave unset for local dev) ---
# The shared SQLite both runtimes use, as an ABSOLUTE path: the listener writes
# detections here and Rails reads them. Must be absolute — the listener resolves
# it from the repo root, Rails from dashboard/, so a relative path would diverge.
#   BIRD_DB=/home/pi/ealta/dashboard/storage/production.sqlite3
# Rails session/cookie signing in production. Generate once with:
#   cd dashboard && RAILS_ENV=production bin/rails secret
#   SECRET_KEY_BASE=...

# Cloud mirror push (the Pi -> your public mirror; the cold path). Set both to enable the
# ealta-push timer; leave unset on a stand-alone/offline Pi and it does nothing.
# The token must match the cloud app's CLOUD_INGEST_TOKEN (which is also what
# switches the cloud's /ingest endpoint on — it's 404 anywhere the token is unset).
#   CLOUD_INGEST_URL=https://your-cloud-host.example/ingest/detections
#   CLOUD_INGEST_TOKEN=

# Offsite backup of the detection history (Litestream -> S3/B2). Set all of these
# to enable the ealta-litestream service; leave unset to skip backup.
#   LITESTREAM_BUCKET=my-ealta-backup
#   LITESTREAM_REGION=eu-west-1
#   LITESTREAM_ACCESS_KEY_ID=...
#   LITESTREAM_SECRET_ACCESS_KEY=...
#   LITESTREAM_ENDPOINT=          # only for Backblaze B2 / non-AWS S3

# Daily "today" summary via Amazon Bedrock (Nova Lite). The ealta-summary timer
# narrates the DailyFacts object into 2-4 bullets; without these it stays on the
# deterministic template (and SUMMARY_LLM_DISABLED=1 forces the template regardless).
# Region + model default to eu-west-1 / the EU Nova Lite inference profile; confirm
# the exact profile id against your account's enabled model access. Credentials come
# from the standard AWS chain (env vars below, a shared profile, or an instance role).
#   BEDROCK_REGION=eu-west-1
#   BEDROCK_MODEL_ID=eu.amazon.nova-lite-v1:0
#   AWS_ACCESS_KEY_ID=...
#   AWS_SECRET_ACCESS_KEY=...
#   SUMMARY_LLM_DISABLED=1        # force the template, never call Bedrock
