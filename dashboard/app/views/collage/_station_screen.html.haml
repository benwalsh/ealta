-# The station screen — the exact pixels the Inky Impression 7.3″ shows (480×800 portrait) and
-# the shooter captures. Shared by /station (the device view) and /station/preview (the framed
-# desktop emulation), so the preview can never drift from the panel.
-#
-# Four zones and nothing else: the day's plate, one piece of news, the almanac bar, and where
-# to find more. There is no wordmark — the panel hangs on a wall in the house it belongs to,
-# and 46px of masthead was the most expensive thing on the screen.
%main.screen.station{ style: "width: #{Station.screen[:width]}px; height: #{Station.screen[:height]}px" }
  -# The plate: the day's flock, packed once and frozen, given every pixel the other three
  -# zones don't need. This is the panel's reason to exist.
  %section.plate{ "aria-label": "Birds recorded today" }
    = render partial: 'panel'

  -# ONE piece of news — the most recent species to make its FIRST appearance today, with the
  -# time. The plate is frozen for the day, so this is the only line that moves; on a day with
  -# nothing new it falls back to the running species count so the panel always says something.
  %p.news
    - if @arrival
      - name = @arrival[:name].public_send(station_lang) || @arrival[:name].en
      %span.news-name= name
      %span.news-when= @arrival[:at].strftime('%H:%M')
    - elsif @species_today.positive?
      %span.news-name= station_text(en: "#{@species_today} species today",
                                    ga: "#{@species_today} speiceas inniu")
    - else
      -# Every day starts at zero and stays there until the first bird — often for hours after
      -# midnight. "0 species today" is true but a bleak thing to hang on a wall, so the panel
      -# says what it is actually doing instead.
      %span.news-name.quiet= station_text(en: 'Listening', ga: 'Ag éisteacht')

  -# The almanac bar — four marks read at a glance (temperature, moon, sunrise, sunset). The
  -# moon is DRAWN, not glyphed, so the panel shows tonight's real phase; item[:svg] is the
  -# SHADOW, and it is inked SOLID here: the panel has no greyscale, so a tint would only
  -# dither into noise at 20px.
  %footer.bar
    - Array(@almanac).each do |item|
      %span
        - if item.key?(:svg)
          %svg.alm-moon{ viewBox: '0 0 24 24', "aria-hidden": "true" }
            %circle{ cx: 12, cy: 12, r: 9, fill: 'none', stroke: 'currentColor', "stroke-width": 1.5 }
            - if item[:svg]
              %path{ d: item[:svg], fill: 'currentColor' }
        - else
          %i.ti{ class: item[:icon], "aria-hidden": "true" }
        = station_text(item[:short] || item)

  -# The tide, on its own line and named: this is the panel in the house on the coast, and the
  -# next turning point at the local beach is the one reading no other surface gives you.
  - if @tide
    %p.tide
      %i.ti.ti-ripple{ "aria-hidden": "true" }
      = station_text(@tide)

  -# Where to see more, and an honest stamp of when this impression was taken — without it a
  -# stopped station shows yesterday's plate forever with nothing to say so. Coarsened to the
  -# half hour (see load_station) so an unchanged panel isn't reprinted every five minutes.
  -# A caret marks a recorder that has gone quiet.
  %p.foot-line
    %span.site= Station.url
    %span.stamp
      - unless @status[:listening]
        %span.quiet △
      = "#{station_text(@printed_on)} · #{@printed_at.strftime('%H:%M')}"
