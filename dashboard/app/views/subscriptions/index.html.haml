- content_for(:title) { "Account · #{Station.site_name}" }

.acct
  %header.acct-top
    %a.acct-home{ href: "/" } ← #{Station.site_name}
    .acct-lang{ role: "group", "aria-label": "Language", data: { controller: "lang" } }
      %button.acct-lang-opt{ type: "button", class: ("is-on" if ui_lang == "en"), data: { to: "en", action: "lang#set" } } EN
      %button.acct-lang-opt{ type: "button", class: ("is-on" if ui_lang == "ga"), data: { to: "ga", action: "lang#set" } } GA
  %h1.acct-h1= bi("Account", "Cuntas")

  %section.acct-me
    - if current_user.avatar_url.present?
      %img.acct-avatar{ src: current_user.avatar_url, alt: current_user.display_name, referrerpolicy: "no-referrer" }
    - else
      %span.acct-avatar.acct-avatar-initial= current_user.display_name.to_s.strip.first&.upcase
    .acct-me-id
      %span.acct-me-name= current_user.display_name
      - if current_user.email.present? && current_user.email != current_user.display_name
        %span.acct-me-email= current_user.email
    - if current_user.admin?
      %a.acct-link.acct-me-admin{ href: admin_path }= bi("Admin", "Riarachán")

  %section.acct-sec
    %h2.acct-h2= bi("The daily letter", "An litir laethúil")
    %ul.acct-rules
      %li.acct-rule
        %span.acct-rule-label= bi("Daily roundup", "Achoimre laethúil")
        = render "cadence", alert_type: "roundup", current: (@roundup ? "digest" : "off")
      %li.acct-rule
        %span.acct-rule-label= bi("Birds you follow", "Éin a leanann tú")
        = render "cadence", alert_type: "species", current: @follow_cadence

  %section.acct-sec
    %h2.acct-h2= bi("Breaking news", "Scéala tapa")
    %ul.acct-rules
      %li.acct-rule
        %span.acct-rule-label= bi("Rarities & first sightings", "Neamhchoitianta & céadfheiceálacha")
        = render "cadence", alert_type: "breaking", current: (@breaking ? "immediate" : "off"),
          on_value: "immediate"

  %section.acct-sec
    %h2.acct-h2= bi("Species you're following", "Speicis a leanann tú")
    - if @follows.any?
      %ul.acct-list
        - @follows.each do |sub|
          - name = BirdName.lookup(sub.sci_name)
          %li.acct-item
            %span.acct-name= name.en
            - if name.ga
              %span.acct-ga= name.ga
            = button_to bi("Unfollow", "Ná lean"), subscription_path(sub), method: :delete, class: "acct-btn acct-remove"
    - else
      %p.acct-empty= bi("You're not following any species yet.", "Níl tú ag leanúint aon speiceas fós.")

    = form_with url: subscriptions_path, method: :post, class: "acct-add" do
      = hidden_field_tag "subscription[alert_type]", "species"
      = select_tag "subscription[sci_name]",
        options_for_select(@species.map { |sci, n| [n.ga ? "#{n.en} · #{n.ga}" : n.en, sci] }),
        prompt: t2("Choose a species…", "Roghnaigh speiceas…"), class: "acct-select"
      = submit_tag t2("Follow", "Lean"), class: "acct-btn acct-add-btn"

  %footer.acct-foot
    = button_to bi("Sign out", "Logáil amach"), logout_path, method: :delete, class: "acct-link"
