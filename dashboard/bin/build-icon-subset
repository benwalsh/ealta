#!/usr/bin/env -S uv run python
"""Subset the Tabler icon webfont to only the glyphs this app actually uses.

The full webfont is ~447KB of woff2 carrying ~5,100 glyphs; the app references 25. It is the
single largest asset on the page and it blocks the first paint, so shipping the whole thing to
save 25 icons is the most expensive rounding error on the site. This regenerates a subset —
woff2 + a matching CSS of just the used classes — cutting it to a few KB.

The used set is discovered by grep, NOT hand-listed, so it can't fall out of sync with the code
on its own: run this after adding or removing a `ti-*` class. `icon_subset_spec.rb` fails the
build if the checked-in subset drifts from what the code uses, which is the backstop for
forgetting to.

    dashboard/bin/build-icon-subset          # regenerate after changing icon usage

Outputs (both checked in, both consumed through Vite so the woff2 is fingerprinted like any
other asset):
  app/javascript/styles/tabler-icons-subset.woff2
  app/javascript/styles/tabler-icons-subset.css

fontTools provides pyftsubset; it is already available via uv (the pipeline uses it).
"""

from __future__ import annotations

import re
import subprocess
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
SEARCH_DIR = ROOT / "app"
TABLER = ROOT / "node_modules" / "@tabler" / "icons-webfont" / "dist"
SRC_CSS = TABLER / "tabler-icons.min.css"
SRC_WOFF2 = TABLER / "fonts" / "tabler-icons.woff2"
OUT_DIR = ROOT / "app" / "javascript" / "styles"
OUT_WOFF2 = OUT_DIR / "tabler-icons-subset.woff2"
OUT_CSS = OUT_DIR / "tabler-icons-subset.css"

# The base `.ti` rule, copied verbatim from the source so subsetted markup behaves identically.
TI_BASE = (
    '.ti{font-family:"tabler-icons" !important;speak:none;font-style:normal;font-weight:normal;'
    "font-variant:normal;text-transform:none;line-height:1;-webkit-font-smoothing:antialiased;"
    "-moz-osx-font-smoothing:grayscale}"
)


def used_icons() -> set[str]:
    """Every `ti-<name>` token that appears anywhere under app/ — TSX, HAML, Ruby alike.

    Ruby weather/almanac maps (today_card.rb) hold these as plain string literals, and the
    front end as class names, so one text scan catches both. A dynamically BUILT class name
    (`ti-#{x}`) would escape this — there are none today, and the spec would catch a regression
    the moment its rendered output stopped matching the subset.
    """
    found: set[str] = set()
    for path in SEARCH_DIR.rglob("*"):
        if not path.is_file():
            continue
        try:
            text = path.read_text(encoding="utf-8", errors="ignore")
        except OSError:
            continue
        # The lookbehind excludes a `ti-` that is really the tail of a word — "anti-repetition",
        # "multi-day" — which would otherwise register as icons `ti-repetition` / `ti-day`. Real
        # usages sit against a quote, space, or class delimiter, never a letter.
        found.update(re.findall(r"(?<![a-zA-Z])ti-[a-z0-9-]+", text))
    return found


def codepoints() -> dict[str, int]:
    """Map every `.ti-name` class to its glyph codepoint, from the source CSS."""
    css = SRC_CSS.read_text()
    pairs = re.findall(r"\.(ti-[a-z0-9-]+):before\{content:\"\\([0-9a-fA-F]+)\"", css)
    return {name: int(hexcp, 16) for name, hexcp in pairs}


def main() -> int:
    if not SRC_WOFF2.is_file():
        print(f"source font missing: {SRC_WOFF2}\nrun `bun install` (or npm/yarn) first", file=sys.stderr)
        return 1

    used = used_icons()
    cp = codepoints()

    resolved = {name: cp[name] for name in sorted(used) if name in cp}
    unknown = sorted(used - cp.keys())
    if unknown:
        # A `ti-` token that is not a real Tabler class — a typo, or an icon removed upstream.
        # Report it rather than silently dropping it, so a misspelled icon is caught here and
        # not as a blank square in production.
        print(f"WARNING: {len(unknown)} ti- token(s) not found in Tabler and skipped: {', '.join(unknown)}",
              file=sys.stderr)

    OUT_DIR.mkdir(parents=True, exist_ok=True)
    unicodes = ",".join(f"U+{c:04X}" for c in sorted(resolved.values()))
    subprocess.run(
        [
            "uv", "run", "pyftsubset", str(SRC_WOFF2),
            f"--unicodes={unicodes}",
            "--flavor=woff2",
            f"--output-file={OUT_WOFF2}",
            "--no-layout-closure",
        ],
        check=True,
        cwd=ROOT,
    )

    rules = "".join(
        f'.{name}:before{{content:"\\{resolved[name]:x}"}}' for name in sorted(resolved)
    )
    css = (
        "/* GENERATED by bin/build-icon-subset — do not edit by hand.\n"
        f"   Tabler Icons subset: {len(resolved)} of ~5,100 glyphs, the set app/ actually uses.\n"
        "   Regenerate after adding or removing a ti-* class; icon_subset_spec.rb guards drift. */\n"
        '@font-face{font-family:"tabler-icons";font-style:normal;font-weight:400;'
        'src:url("./tabler-icons-subset.woff2") format("woff2")}\n'
        f"{TI_BASE}\n{rules}\n"
    )
    OUT_CSS.write_text(css)

    before_kb = SRC_WOFF2.stat().st_size / 1024
    after_kb = OUT_WOFF2.stat().st_size / 1024
    print(f"subset {len(resolved)} icons: {before_kb:.0f}KB -> {after_kb:.1f}KB woff2")
    print(f"  {OUT_WOFF2.relative_to(ROOT)}")
    print(f"  {OUT_CSS.relative_to(ROOT)}")
    return 0


if __name__ == "__main__":
    sys.exit(main())
