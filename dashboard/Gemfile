source 'https://rubygems.org'
ruby file: '.ruby-version'

gem 'rails', '8.1.3'

gem 'haml-rails'
gem 'propshaft'
gem 'puma'
gem 'sqlite3', '>= 2.1'
gem 'stimulus-rails'
gem 'turbo-rails'
# The `/` front end is a Vite + React SPA; /kiosk and /station stay server-rendered
# HAML and load the same Vite-built Stimulus/Turbo bundle. vite_rails owns the JS
# build (replacing jsbundling/bun.config.js); vite_react adds the React refresh tag.
gem 'bootsnap', require: false
gem 'thruster', require: false
gem 'tzinfo-data', platforms: %i[windows jruby]
gem 'vite_rails'
gem 'vite_react'

# The daily "today" summary is narrated by Amazon Nova Lite via Bedrock. Pure-Ruby
# SDK (no native build), so it installs on the ARM Pi; only the summary path loads
# it, and it degrades to a deterministic template when Bedrock is unreachable.
gem 'aws-sdk-bedrockruntime', require: false

# Google sign-in (OAuth) — no hand-rolled auth. Both gems are pure Ruby (no
# native builds), so they install fine on the ARM Pi. rails_csrf_protection makes
# the OmniAuth request phase a CSRF-protected POST, as OmniAuth 2 requires.
gem 'omniauth-google-oauth2'
gem 'omniauth-rails_csrf_protection'

# The cloud mirror runs this same app on RDS MySQL. trilogy is a pure-Ruby MySQL
# adapter — no libmysqlclient to compile into the container image. The Pi never
# needs it: `bundle config set --without cloud` (see deploy/provision.sh).
group :cloud do
  gem 'aws-sdk-sesv2' # alert emails via SES templated-email (Notifier); cloud-only
  gem 'trilogy'
end

# The job runner + its dashboard. Solid Queue runs the once-a-day enrichment + digest
# sweep (DailyEmailSweep) — DB-backed (reuses RDS, no Redis), inside Puma via its plugin
# so there's no extra worker container. Mission Control is the admin-gated /jobs
# dashboard: watch each sweep run, inspect its args + the AI text it produced, retry a
# failure. In :development too so the dashboard can be previewed on the desktop. NOT on
# the Pi: it runs no jobs (production env; provision.sh sets --without cloud, and
# production never requires the development group).
group :development, :cloud do
  gem 'mission_control-jobs'
  gem 'solid_queue'
end

group :development, :test do
  gem 'awesome_print'
  gem 'debug', platforms: %i[mri windows], require: 'debug/prelude'
  gem 'rspec-rails'
  gem 'rubocop', require: false
  gem 'rubocop-factory_bot', require: false
  gem 'rubocop-performance', require: false
  gem 'rubocop-rails', require: false
  gem 'rubocop-rspec', require: false
  gem 'rubocop-rspec_rails', require: false
  gem 'timecop'
end

group :development do
  gem 'brakeman', require: false
  gem 'web-console'
end

group :test do
  gem 'database_cleaner-active_record'
  gem 'factory_bot_rails'
  gem 'faker'
  gem 'shoulda-matchers'
end
